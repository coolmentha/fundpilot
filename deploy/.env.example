# 生产部署环境变量模板。
# 在 VPS 仓库根目录复制为 .env 并填真实值:.env 已被根 .gitignore 忽略,不会入库。
# 升级镜像版本:改 TAG 后 docker compose -f deploy/docker-compose.prod.yml pull && up -d

# 数据库账号(首次部署后请勿改,PostgreSQL 已用初值初始化)
DB_USERNAME=fundpilot

# 数据库密码:务必改成强口令,首次部署创建库时写入
DB_PASSWORD=change-me-to-strong-password

# 部署的镜像 tag,对应 git tag(如 v0.0.1);latest 跟随最新发布
TAG=latest
