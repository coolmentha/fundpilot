{
  "uid": "spring-boot-overview",
  "title": "Spring Boot Overview",
  "tags": ["spring-boot", "fundpilot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "JVM 堆内存已用",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "bytes"},
        "overrides": []
      },
      "options": {"legend": {"showLegend": true, "displayMode": "table", "placement": "bottom"}},
      "targets": [
        {"refId": "A", "expr": "jvm_memory_used_bytes{area=\"heap\"}", "legendFormat": "{{id}}"}
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP 请求速率 (req/s)",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "reqps"},
        "overrides": []
      },
      "options": {"legend": {"showLegend": true, "displayMode": "table", "placement": "bottom"}},
      "targets": [
        {"refId": "A", "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (method, status)", "legendFormat": "{{method}} {{status}}"}
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "定时任务执行次数 (5min)",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },
      "options": {"legend": {"showLegend": true, "displayMode": "table", "placement": "bottom"}},
      "targets": [
        {"refId": "A", "expr": "increase(job_execution_total[5m])", "legendFormat": "{{job}} {{result}}"}
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "定时任务耗时 P99 (s)",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": []
      },
      "options": {"legend": {"showLegend": true, "displayMode": "table", "placement": "bottom"}},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.99, sum(rate(job_duration_seconds_bucket[5m])) by (le, job))", "legendFormat": "{{job}}"}
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "HTTP 500 错误 (5min)",
      "gridPos": {"x": 0, "y": 16, "w": 24, "h": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}},
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background"},
      "targets": [
        {"refId": "A", "expr": "sum(increase(http_server_errors_total[5m]))", "legendFormat": "500 errors"}
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Backend 应用日志",
      "gridPos": {"x": 0, "y": 22, "w": 24, "h": 10},
      "datasource": {"type": "loki", "uid": "loki"},
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {"refId": "A", "expr": "{container_name=\"fundpilot-backend\"}", "datasource": {"type": "loki", "uid": "loki"}}
      ]
    }
  ]
}
